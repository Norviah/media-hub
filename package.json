{
  "name": "watch-together",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:migrate": "npx prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:generate": "npx prisma generate --schema ./prisma/schema.prisma",
    "prisma:studio": "pnpx prisma studio",
    "build:production": "pnpx prisma generate && pnpx prisma migrate deploy && next build",
    "build:documentation": "./node_modules/ts-node/dist/bin.js -r tsconfig-paths/register ./scripts/openapi.ts",
    "build:prisma": "pnpm run prisma:migrate && pnpm run prisma:generate",
    "build:prisma:reset": "rm -rf ./prisma/migrations ; pnpm run prisma:migrate && pnpm run prisma:generate",
    "release:patch": "./node_modules/standard-version/bin/cli.js --release-as patch && pnpm run release",
    "release:minor": "./node_modules/standard-version/bin/cli.js --release-as minor && pnpm run release",
    "release:major": "./node_modules/standard-version/bin/cli.js --release-as major && pnpm run release",
    "release": "git push --follow-tags origin master"
  },
  "dependencies": {
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@faker-js/faker": "^7.6.0",
    "@fontsource/inter": "^4.5.15",
    "@fontsource/outfit": "^4.5.11",
    "@iconify/react": "^4.1.0",
    "@mui/icons-material": "^5.11.16",
    "@mui/lab": "5.0.0-alpha.126",
    "@mui/material": "^5.12.0",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@norviah/config": "^4.3.0",
    "@prisma/client": "^4.12.0",
    "app-root-path": "^3.1.0",
    "bcryptjs": "^2.4.3",
    "change-case": "^4.1.2",
    "clsx": "^1.2.1",
    "date-fns": "^2.29.3",
    "http-status-codes": "^2.2.0",
    "lodash": "^4.17.21",
    "next": "13.3.0",
    "next-auth": "^4.22.0",
    "notistack": "^3.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.43.9",
    "simplebar-react": "^3.2.3",
    "ts-deepmerge": "^6.0.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/lodash": "^4.14.192",
    "@types/node": "18.15.11",
    "@types/react": "18.0.34",
    "@types/react-dom": "18.0.11",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/ws": "^8.5.4",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "eslint": "8.38.0",
    "eslint-config-next": "13.3.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "openapi-types": "^12.1.0",
    "prisma": "^4.12.0",
    "swagger-jsdoc": "^6.2.8",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "type-fest": "^3.8.0",
    "typescript": "5.0.4"
  }
}
