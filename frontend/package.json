{
  "name": "frontend",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "postinstall": "prisma generate",
    "prisma:migrate": "npx prisma migrate dev --name $(date +\"%m/%d/%Y\") --schema ./prisma/schema.prisma",
    "prisma:generate": "npx prisma generate --schema ./prisma/schema.prisma",
    "prisma:studio": "pnpx prisma studio",
    "build:production": "pnpx prisma generate && pnpx prisma migrate deploy && next build",
    "build:prisma": "pnpm run prisma:migrate && pnpm run prisma:generate",
    "build:prisma:reset": "rm -rf ./prisma/migrations ; pnpm run prisma:migrate && pnpm run prisma:generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/norviah/watch-together.git"
  },
  "author": "norviah",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/norviah/watch-together/issues"
  },
  "homepage": "https://github.com/norviah/watch-together#readme",
  "dependencies": {
    "@emotion/react": "^11.10.5",
    "@emotion/styled": "^11.10.5",
    "@fontsource/roboto": "^4.5.8",
    "@mui/icons-material": "^5.11.0",
    "@mui/material": "^5.11.6",
    "@next-auth/prisma-adapter": "^1.0.5",
    "@next/font": "13.1.6",
    "@norviah/config": "^4.3.0",
    "@prisma/client": "^4.12.0",
    "bcryptjs": "^2.4.3",
    "csstype": "^3.1.1",
    "http-status-codes": "^2.2.0",
    "next": "13.1.6",
    "next-auth": "^4.20.1",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-toastify": "^9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@types/app-root-path": "^1.2.4",
    "@types/bcryptjs": "^2.4.2",
    "@types/node": "18.11.18",
    "@types/react": "18.0.27",
    "@types/react-dom": "18.0.10",
    "@types/ws": "^8.5.4",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "eslint": "8.33.0",
    "eslint-config-next": "13.1.6",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "prettier": "^2.8.3",
    "prisma": "^4.12.0",
    "type-fest": "^3.7.2",
    "typescript": "4.9.5"
  }
}
